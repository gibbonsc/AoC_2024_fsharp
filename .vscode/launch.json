    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
            "name": ".NET Core Launch active (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${fileDirname}/bin/Debug/net10.0/${fileDirname##*/}.dll",
            "args": [],
            "cwd": "${fileDirname}",
            "stopAtEntry": false,
            "console": "internalConsole",
            "justMyCode": false
        },
        {
            "name": "Day1part1",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build Day1part1",
            "program": "${workspaceFolder}/Day1part1/bin/Debug/net10.0/Day1part1.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Day1part1",
            "stopAtEntry": false,
            "console": "internalConsole",
            "justMyCode": false
        },
        {
            "name": "Day3part1 Tests (debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build Day3part1",
            "program": "${workspaceFolder}/Day3part1/tests/Day3part1.Tests/bin/Debug/net10.0/Day3part1.Tests.dll",
            "args": [
                "--debug"
            ],
            "cwd": "${workspaceFolder}/Day3part1/tests/Day3part1.Tests",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Day3part2",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build Day3part2",
            "program": "${workspaceFolder}/Day3part2/bin/Debug/net10.0/Day3part2.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Day3part2",
            "stopAtEntry": false,
            "console": "internalConsole",
            "justMyCode": false
        },
        {
            "name": "Day4part1",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build Day4part1",
            "program": "${workspaceFolder}/Day4part1/bin/Debug/net10.0/Day4part1.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Day4part1",
            "stopAtEntry": false,
            "console": "internalConsole",
            "justMyCode": false
        },
   ]
}